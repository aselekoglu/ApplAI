{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["agent.ts", "lib/**/*.ts", "lib/**/*.js", "tools/**/*.ts", "workflows/**/*.ts", "evals/**/*.ts"]
}
